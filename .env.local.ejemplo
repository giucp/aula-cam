# Copiá este archivo como  .env.local  y completá los valores.
# .env.local NUNCA se commitea (está en .gitignore). Este .ejemplo SÍ (sin valores).

# Cuentas Moodle de lectura para la fábrica de contenido curado.
# A = cuenta del grado que se cura como "5to grado"; B = como "1er año".
MOODLE_USER_A=
MOODLE_PASS_A=
MOODLE_USER_B=
MOODLE_PASS_B=

# Supabase (las mismas que ya usa el proyecto en Vercel).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
